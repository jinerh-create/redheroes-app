---
import AppLayout from '../../layouts/AppLayout.astro';
import RequestDetail from '../../components/requests/RequestDetail';
import BottomNav from '../../components/nav/BottomNav';
const user = (Astro.locals as any).user;
if (!user) return Astro.redirect('/login');
const { id } = Astro.params;
const safeUser = { ...user }; delete (safeUser as any).password_hash;
---
<AppLayout title="Request Detail">
  <header class="app-header">
    <a href="/requests" style="color:var(--text-muted);text-decoration:none;font-size:1.25rem;margin-right:0.25rem;">←</a>
    <div>
      <div class="app-header-title">Request Detail</div>
      <div class="app-header-sub">Blood request info</div>
    </div>
  </header>
  <RequestDetail client:load requestId={id} user={safeUser} />
  <BottomNav client:load active="requests" />
</AppLayout>
