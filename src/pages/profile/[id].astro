---
import AppLayout from '../../layouts/AppLayout.astro';
import ProfilePage from '../../components/profile/ProfilePage';
import BottomNav from '../../components/nav/BottomNav';
const user = (Astro.locals as any).user;
if (!user) return Astro.redirect('/login');
const { id } = Astro.params;
const safeUser = { ...user }; delete (safeUser as any).password_hash;
---
<AppLayout title="Profile">
  <header class="app-header">
    <a href="/" style="color:var(--text-muted);text-decoration:none;font-size:1.25rem;margin-right:0.25rem;">←</a>
    <div>
      <div class="app-header-title">Profile</div>
      <div class="app-header-sub">Donor information</div>
    </div>
  </header>
  <ProfilePage client:load profileId={id} user={safeUser} />
  <BottomNav client:load active={id === safeUser.id ? 'profile' : ''} />
</AppLayout>
