---
import AppLayout from '../layouts/AppLayout.astro';
import RequestsPage from '../components/requests/RequestsPage';
import BottomNav from '../components/nav/BottomNav';
const user = (Astro.locals as any).user;
if (!user) return Astro.redirect('/login');
const safeUser = { ...user }; delete (safeUser as any).password_hash;
---
<AppLayout title="Blood Requests">
  <header class="app-header">
    <a href="/" style="color:var(--text-muted);text-decoration:none;font-size:1.25rem;margin-right:0.25rem;">←</a>
    <div>
      <div class="app-header-title">Blood Requests</div>
      <div class="app-header-sub">Urgent needs nearby</div>
    </div>
  </header>
  <RequestsPage client:load user={safeUser} />
  <BottomNav client:load active="requests" />
</AppLayout>
