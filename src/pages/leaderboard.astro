---
import AppLayout from '../layouts/AppLayout.astro';
import Leaderboard from '../components/leaderboard/Leaderboard';
import BottomNav from '../components/nav/BottomNav';
const user = (Astro.locals as any).user;
if (!user) return Astro.redirect('/login');
const safeUser = { ...user }; delete (safeUser as any).password_hash;
---
<AppLayout title="Leaderboard">
  <header class="app-header">
    <a href="/" style="color:var(--text-muted);text-decoration:none;font-size:1.25rem;margin-right:0.25rem;">←</a>
    <div>
      <div class="app-header-title">Heroes Board</div>
      <div class="app-header-sub">Top blood donors</div>
    </div>
  </header>
  <Leaderboard client:load user={safeUser} />
  <BottomNav client:load active="leaderboard" />
</AppLayout>
