---
import AppLayout from '../layouts/AppLayout.astro';
import FindDonors from '../components/donors/FindDonors';
import BottomNav from '../components/nav/BottomNav';
const user = (Astro.locals as any).user;
if (!user) return Astro.redirect('/login');
const safeUser = { ...user }; delete (safeUser as any).password_hash;
---
<AppLayout title="Find Donors">
  <header class="app-header">
    <a href="/" style="color:var(--text-muted);text-decoration:none;font-size:1.25rem;margin-right:0.25rem;">←</a>
    <div>
      <div class="app-header-title">Find Donors</div>
      <div class="app-header-sub">Compatible blood types near you</div>
    </div>
  </header>
  <FindDonors client:load user={safeUser} />
  <BottomNav client:load active="find" />
</AppLayout>
