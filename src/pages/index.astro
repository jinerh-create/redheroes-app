---
import AppLayout from '../layouts/AppLayout.astro';
import Dashboard from '../components/home/Dashboard';
import BottomNav from '../components/nav/BottomNav';
const user = (Astro.locals as any).user;
if (!user) return Astro.redirect('/login');
const safeUser = { ...user };
delete (safeUser as any).password_hash;
---
<AppLayout title="Home">
  <header class="app-header">
    <img src="/logo.png" alt="RedHeroes" class="header-logo" />
    <div>
      <div class="app-header-title">REDHEROES</div>
      <div class="app-header-sub">Blood Donation Network</div>
    </div>
    <div style="margin-left:auto;display:flex;align-items:center;gap:0.5rem;">
      <a href="/notifications" style="color:var(--text-muted);text-decoration:none;font-size:1.25rem;">🔔</a>
    </div>
  </header>
  <Dashboard client:load user={safeUser} />
  <BottomNav client:load active="home" />
</AppLayout>
